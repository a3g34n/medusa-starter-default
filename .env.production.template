# Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=secure_password_here
POSTGRES_DB=medusa_db

# Redis
REDIS_URL=redis://redis:6379

# Medusa
NODE_ENV=production
jwt_secret=something_super_secret_and_long
cookie_secret=something_super_secret_and_long

# CORS - Update these with your actual production domains!
STORE_CORS=http://localhost:8000,https://your-storefront-domain.com
ADMIN_CORS=http://localhost:7000,http://localhost:9000,https://your-admin-domain.com
AUTH_CORS=http://localhost:7000,http://localhost:8000,http://localhost:9000,https://your-storefront-domain.com,https://your-admin-domain.com

# Database URL is constructed in docker-compose, but if needed explicitly:
# DATABASE_URL=postgres://postgres:secure_password_here@postgres:5432/medusa_db

# MinIO / S3 (Optional - needed for file uploads in production)
# MINIO_ENDPOINT=
# MINIO_ACCESS_KEY=
# MINIO_SECRET_KEY=
# MINIO_BUCKET=
